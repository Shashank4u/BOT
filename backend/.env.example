# Application
APP_NAME=AI Trading Assistant
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars

# Database (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./data/trading_assistant.db

# PostgreSQL (uncomment for production)
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=trading_user
# POSTGRES_PASSWORD=change_me
# POSTGRES_DB=trading_assistant

# Redis
REDIS_URL=redis://redis:6379/0

# Trading — ALWAYS start in DEMO mode
TRADING_MODE=demo
MT5_USE_MOCK=true
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=XMGlobal-MT5

# Optional API key for VPS (no login UI — set header X-API-Key)
# API_KEY=your-secret-key-here

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
